# Local infrastructure used by docker-compose.yml
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=replace-with-a-long-local-password
POSTGRES_DB=taskflow

# Backend runtime (set these in the deployment platform's secret manager)
DATABASE_URL=postgresql://taskflow:replace-with-a-long-local-password@localhost:5432/taskflow
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=generate-a-unique-32-plus-character-secret
JWT_REFRESH_SECRET=generate-a-different-unique-32-plus-character-secret
FRONTEND_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com
